# =============================================================================
# casarei.online — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env with real credentials.
# =============================================================================

# Supabase (frontend — VITE_ prefix exposes to browser)
VITE_SUPABASE_PROJECT_ID=your-project-id
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# =============================================================================
# Edge Functions secrets (configure via: supabase secrets set KEY=value)
# These are NOT used by the frontend — only by Supabase Edge Functions.
# =============================================================================

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 32-byte hex key for AES-GCM encryption of MP credentials
ENCRYPTION_KEY=your-64-char-hex-key

# Mercado Pago webhook signature verification
MERCADO_PAGO_WEBHOOK_SECRET=seu_webhook_secret_do_mercado_pago_aqui

# Allowed origin for CORS and payment redirect URLs
ALLOWED_ORIGIN=https://your-domain.com.br

# Resend Email Service
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=contato@seu-dominio.com.br

